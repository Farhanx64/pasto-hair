# --- Payload / DB ---
PAYLOAD_SECRET=replace-with-a-long-random-string
# libSQL/SQLite connection. Local file DB inside the private .data dir.
DATABASE_URI=file:./.data/pasto.db
# Private, persistent data dir (DB + media). On cPanel set to an ABSOLUTE path OUTSIDE public_html.
DATA_DIR=./.data
MEDIA_DIR=./.data/media

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google Calendar (direct API; fill before enabling booking) ---
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_CLIENT_EMAIL=
GOOGLE_CALENDAR_PRIVATE_KEY=

# --- Email (Resend) ---
EMAIL_FROM=
RESEND_API_KEY=
